{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "gsd-builder": {
      "description": "Gatekeeper builder agent. Makes failing tests pass by implementing code. No web access, no destructive operations.",
      "mode": "primary",
      "model": "zai-coding-plan/glm-5",
      "tools": {
        "bash": true,
        "read": true,
        "write": true,
        "edit": true,
        "grep": true,
        "glob": true,
        "list": true,
        "question": true,
        "websearch": false,
        "webfetch": false
      },
      "permission": {
        "bash": "ask",
        "edit": "allow",
        "write": "allow"
      },
      "temperature": 1.0
    }
  }
}
